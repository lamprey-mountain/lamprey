{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id as \"id: Uuid\", lifecycle_seq, deleted_at, removed_at\n            FROM message\n            WHERE channel_id = $1\n              AND lifecycle_seq > $2\n              AND lifecycle_seq <= $3\n              AND lifecycle_seq != created_seq\n            ORDER BY lifecycle_seq ASC, id ASC\n            ",
