{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    rt.code,\n                    rt.name,\n                    rt.description,\n                    rt.created_at,\n                    rt.updated_at,\n                    rt.creator_id,\n                    rt.source_room_id,\n                    rt.snapshot,\n                    rt.dirty\n                FROM room_templates rt\n                WHERE rt.creator_id = $1 AND rt.code > $2 AND rt.code < $3\n                ORDER BY (CASE WHEN $4 = 'f' THEN rt.code END) ASC, rt.code DESC\n                LIMIT $5\n                ",
