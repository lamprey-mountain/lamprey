interface network {
    record http-request {
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    }

    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    }

    // resource network-manager {
    //     fetch: func(req: request) -> result<response, string>;
    // }
}

world script-world {
    import log;
    // import env;
    // import storage;
    import network;
    // import lamprey:base/env/logging;

    use types.{script-metadata};
    use network.{http-request, http-response};

    export get-metadata:     func() -> script-metadata;

    export handle-http: func(id: string, req: http-request) -> http-response;
    export handle-trigger: func(id: string);
}
