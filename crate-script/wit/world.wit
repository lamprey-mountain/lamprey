package lamprey:scripting@0.1.0;

interface types {
    type script-id = string;
    type run-id = string;
    type kv-version = u64;

    variant value {
        text(string),
        integer(s64),
        float(f64),
        boolean(bool),
        bytes(list<u8>),
        timestamp(u64), // unix millis
        // error: type `value` depends on itself
        // array(list<value>),
        // object(list<tuple<string, value>>),
        none,
    }

    record script-metadata {
        name:        string,
        description: option<string>,
        version:     option<string>,
        license:     option<string>,
        authors:     list<string>,
        inputs:      list<script-input>,
    }

    variant script-input-kind {
        trigger,
        http,
    }

    record script-input {
        id:    string,
        label: string,
        kind:  script-input-kind,
        // TODO: capabilities
    }
}

interface log {
    enum level {
        debug,
        info,
        warning,
        error
    }

    record log-entry {
        content: string,
        level: level,
        attributes: list<tuple<string, string>>,
    }

    log: func(level: level, content: string, attributes: list<tuple<string, string>>);
}

