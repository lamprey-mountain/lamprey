{
  "db_name": "PostgreSQL",
  "query": "SELECT id, room_id, channel_id as \"channel_id!\", message_id as \"message_id!\", type as \"ty!: DbNotificationType\", added_at, read_at\nFROM inbox\nWHERE user_id = $1\n  AND ($2 OR read_at IS NULL)\n  AND (array_length($3::uuid[], 1) IS NULL OR room_id = ANY($3))\n  AND (array_length($4::uuid[], 1) IS NULL OR channel_id = ANY($4))\n  AND id > $5 AND id < $6\nORDER BY (CASE WHEN $7 = 'f' THEN id END), id DESC\nLIMIT $8\n",
